rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    match /folhetos/{folhetoId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /documentos/{documentoId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /tabelas_preco/{tabelaId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /projetos/{projetoId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && request.auth.uid == resource.data.revendedorId;
    }

    match /produtos_modelos/{produtoId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /kits_modelos/{kitId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // Usuário comum pode atualizar apenas perfil/preferências próprias.
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.isAdmin == resource.data.isAdmin
        && request.resource.data.role == resource.data.role;

      // Criação/edição estrutural de users fica com o backend/admin.
      allow create, delete: if isAdmin();
    }

    match /app_settings/{settingId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
